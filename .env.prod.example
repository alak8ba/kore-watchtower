# ═════════════════════════════════════════════════════════════════════════
# KORE WATCHTOWER — Configuration (PRODUCTION)
# Copier en `.env.prod` (gitignore) puis renseigner les variables.
# ═════════════════════════════════════════════════════════════════════════

# Intervalle de scrutation (secondes). 3600 = 1h.
WATCHTOWER_POLL_INTERVAL=3600

# Nettoyer les anciennes images apres update (true recommande).
WATCHTOWER_CLEANUP=true

# Notification — webhook generique (Slack, Discord, etc.). Vide = pas de notif.
# Exemple Slack : https://hooks.slack.com/services/XXX/YYY/ZZZ
WATCHTOWER_NOTIFICATION_URL=

# Email Let's Encrypt (utilise nulle part ici, place pour coherence ecosystem).
# LETSENCRYPT_EMAIL=contact@example.com
